---
import renderPlaceholder from '../assets/drawer-divider/placeholder.svg';
import drawerDivider from '../assets/drawer-divider/craftsman_dividers.png';

const shell =
	"min-h-dvh bg-white dark:bg-zinc-950 font-[system-ui,-apple-system,BlinkMacSystemFont,'Segoe_UI','Helvetica_Neue',Arial,sans-serif] text-zinc-900 dark:text-zinc-50 **:box-border";
const eyebrow = 'text-[0.6875rem] font-medium uppercase tracking-[0.28em] text-zinc-400 dark:text-zinc-500';
const thingiverseUrl = 'https://www.thingiverse.com/thing:7301721';
---

<div class={shell}>
	<header class="border-b border-zinc-200 dark:border-zinc-800 bg-white/90 dark:bg-zinc-950/90 backdrop-blur-sm">
		<div
			class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-6 py-4"
		>
			<a
				href="/product-design"
				class="text-sm text-zinc-500 transition-colors duration-200 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-50"
			>
				← Product design
			</a>
			<p class={`m-0 text-right ${eyebrow}`}>1.3 Divider family</p>
		</div>
	</header>

	<section class="mx-auto max-w-6xl px-6 pt-12 pb-10 sm:pt-16 sm:pb-12">
		<p class={`m-0 ${eyebrow}`}>1.3 Craftsman drawer divider family</p>
		<h1 class="m-0 mt-2 max-w-4xl text-3xl font-bold leading-[1.12] tracking-tight sm:text-4xl lg:text-5xl">
			Craftsman Drawer Divider Family
		</h1>
		<hr class="mt-6 max-w-2xl border-0 border-t border-zinc-200 dark:border-zinc-800" />
	</section>

	<section class="mx-auto max-w-6xl px-6 pb-20 sm:pb-24">
		<div class="grid grid-cols-1 items-start gap-12 lg:grid-cols-2 lg:gap-16">
			<div>
				<p class={`m-0 ${eyebrow}`}>Project</p>
				<div class="mt-5 space-y-5 text-base leading-relaxed text-zinc-700 dark:text-zinc-300">
					<p>
						Design a modular drawer divider system for Craftsman tool storage. The family of parts
						must maintain a consistent design language.
					</p>
					<p>
						When I looked online for dividers for the Craftsman 30-drawer organiser, I could only
						find simple dividers that use the existing tabs. I needed to divide each drawer into
						four sections to store resistors and other small components, so I designed a product
						family that helps people organise that space more deliberately.
					</p>
				</div>
				<p class="mt-10">
					<a
						href={thingiverseUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-2 rounded-lg border border-zinc-300 dark:border-zinc-600 bg-white dark:bg-zinc-950 px-4 py-2.5 text-sm font-medium text-zinc-900 dark:text-zinc-50 shadow-sm transition-colors duration-200 hover:border-zinc-400 dark:hover:border-zinc-500 hover:bg-zinc-50 dark:bg-zinc-900"
					>
						View on Thingiverse
						<span class="text-zinc-400 dark:text-zinc-500" aria-hidden="true">↗</span>
					</a>
				</p>
				<p class="mt-4 text-sm text-zinc-400 dark:text-zinc-500">
					<a
						href={thingiverseUrl}
						class="break-all text-inherit underline decoration-zinc-300 dark:decoration-zinc-600 underline-offset-2 transition-colors hover:text-zinc-600 dark:text-zinc-400 hover:decoration-zinc-500 dark:hover:decoration-zinc-400"
						target="_blank"
						rel="noopener noreferrer"
					>
						thingiverse.com/thing:7301721
					</a>
				</p>
			</div>

			<figure
				class="m-0 overflow-hidden rounded-2xl border border-zinc-200 dark:border-zinc-800 bg-zinc-100 dark:bg-zinc-800/70 shadow-sm lg:sticky lg:top-6"
			>
				<img
					src={drawerDivider.src}
					width={1200}
					height={900}
					alt="Modular transparent drawer bins with zero to three gray dividers, showing one through four compartments"
					class="h-auto w-full object-cover"
					loading="eager"
					decoding="async"
				/>
				<figcaption class="border-t border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-950 px-4 py-3 text-sm text-zinc-500 dark:text-zinc-400">
					Family progression: empty bin through four-way split using the same divider language.
				</figcaption>
			</figure>
		</div>
	</section>

	<footer class="border-t border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-950">
		<div
			class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-6 py-10 text-sm text-zinc-500 dark:text-zinc-400"
		>
			<span>Bora Tavman — Craftsman drawer dividers</span>
			<a
				href="/product-design"
				class="text-zinc-900 dark:text-zinc-50 underline decoration-zinc-300 dark:decoration-zinc-600 underline-offset-4 transition-colors hover:decoration-zinc-900 dark:hover:decoration-zinc-300"
			>
				Back to contents
			</a>
		</div>
	</footer>
</div>
