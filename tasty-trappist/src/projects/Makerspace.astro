---
import photoPlaceholder from '../assets/makerspace/placeholder.svg';
import makerspace from '../assets/makerspace/inmakerspace.jpg';

/** Served from `public/documents/` so the URL works the same in dev, preview, and static hosting. */
const makerspaceImprovementsPdf = `${import.meta.env.BASE_URL}documents/MakerSpace_Improvements.pdf`;

const shell =
	"min-h-dvh bg-white dark:bg-zinc-950 font-[system-ui,-apple-system,BlinkMacSystemFont,'Segoe_UI','Helvetica_Neue',Arial,sans-serif] text-zinc-900 dark:text-zinc-50 **:box-border";
const eyebrow = 'text-[0.6875rem] font-medium uppercase tracking-[0.28em] text-zinc-400 dark:text-zinc-500';
const label = 'text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-zinc-400 dark:text-zinc-500';
---

<div class={shell}>
	<header class="border-b border-zinc-200 dark:border-zinc-800 bg-white/90 dark:bg-zinc-950/90 backdrop-blur-sm">
		<div
			class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-6 py-4"
		>
			<div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
				<a
					href="/"
					class="text-zinc-500 transition-colors duration-200 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-50"
					>← Home</a
				>
				<a
					href="/technical-leadership"
					class="text-zinc-500 transition-colors duration-200 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-50"
					>← Technical leadership</a
				>
			</div>
			<p class={`m-0 text-right ${eyebrow}`}>3.2 Makerspace operations</p>
		</div>
	</header>

	<section class="mx-auto max-w-6xl px-6 pt-12 pb-10 sm:pt-16 sm:pb-14">
		<p class={`m-0 ${eyebrow}`}>3.2 Makerspace operations overhaul</p>
		<h1 class="m-0 mt-2 text-3xl font-bold leading-[1.12] tracking-tight sm:text-4xl lg:text-5xl">
			Makerspace Operations Overhaul
		</h1>
		<hr class="mt-6 border-0 border-t border-zinc-200 dark:border-zinc-800" />
	</section>

	<section class="mx-auto max-w-6xl px-6 pb-20 sm:pb-24">
		<div class="grid grid-cols-1 items-start gap-12 lg:grid-cols-2 lg:gap-16">
			<div>
				<p class={`m-0 ${label}`}>Context</p>
				<div class="mt-5 space-y-5 text-base leading-relaxed text-zinc-700 dark:text-zinc-300">
					<p>
						While working at the University of Ottawa’s CEED Makerspace, I noticed recurring
						problems: wasted filament, disorganised storage, inconsistent training, and maintenance
						gaps across 30+ machines.
					</p>
					<p>
						On my own initiative, I wrote a 12-page improvement proposal and submitted it to my
						manager.
					</p>
					<a
						href={makerspaceImprovementsPdf}
						target="_blank"
						rel="noopener noreferrer"
						class="text-zinc-900 dark:text-zinc-50 underline decoration-zinc-300 dark:decoration-zinc-600 underline-offset-4 transition-colors hover:decoration-zinc-900 dark:hover:decoration-zinc-300"
						>View the full document</a
					>
				</div>
			</div>

			<figure
				class="m-0 overflow-hidden rounded-2xl border border-zinc-200 dark:border-zinc-800 bg-zinc-100 dark:bg-zinc-800/70 shadow-sm lg:sticky lg:top-6"
			>
				<img
					src={makerspace.src}
					width={900}
					height={1200}
					alt="Makerspace workbench: staff behind a wooden bench with monitor and tools, industrial ceiling and lighting"
					class="aspect-3/4 h-auto w-full object-cover sm:aspect-4/5 lg:aspect-3/4"
					loading="eager"
					decoding="async"
				/>
				<figcaption class="border-t border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-950 px-4 py-3 text-center text-sm text-zinc-500 dark:text-zinc-400">
					CEED Makerspace
				</figcaption>
			</figure>
		</div>
	</section>

	<footer class="border-t border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-950">
		<div
			class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-6 py-10 text-sm text-zinc-500 dark:text-zinc-400"
		>
			<span>Bora Tavman — Makerspace operations</span>
			<a
				href="/technical-leadership"
				class="text-zinc-900 dark:text-zinc-50 underline decoration-zinc-300 dark:decoration-zinc-600 underline-offset-4 transition-colors hover:decoration-zinc-900 dark:hover:decoration-zinc-300"
			>
				Back to contents
			</a>
		</div>
	</footer>
</div>
