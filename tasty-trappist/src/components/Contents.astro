---
import { productDesignProjects as projects } from '../data/product-design';

const leftCol = projects.slice(0, 3);
const rightCol = projects.slice(3, 6);

const shell =
	"box-border flex min-h-dvh flex-col bg-white dark:bg-zinc-950 font-[system-ui,-apple-system,BlinkMacSystemFont,'Segoe_UI','Helvetica_Neue',Arial,sans-serif] text-black dark:text-zinc-50 **:box-border";
const pageX = "px-[clamp(1.25rem,5vw,3.5rem)]";
const pageY = "py-[clamp(1.25rem,4vw,2.5rem)]";
---

<div class={shell}>
	<header
		class="border-b border-zinc-300 bg-white/90 backdrop-blur-sm dark:border-zinc-700 dark:bg-zinc-950/90 md:border-b-0"
	>
		<div class={`flex justify-end py-4 ${pageX}`}>
			<p
				class="m-0 text-[0.6875rem] font-medium uppercase tracking-[0.28em] text-zinc-400 dark:text-zinc-500"
			>
				Product design
			</p>
		</div>
	</header>

	<div class:list={['flex-1', pageX, pageY]}>
        <header>
            <h1
                class="m-0 text-[clamp(2rem,5vw,2.75rem)] font-bold leading-tight tracking-tight text-black dark:text-zinc-50"
            >
                Contents
            </h1>
            <hr class="mb-0 mt-6 h-px w-full border-0 bg-zinc-300 dark:bg-zinc-600" />
        </header>

        <div
            class="mt-10 grid grid-cols-1 gap-x-[clamp(2rem,8vw,5rem)] gap-y-0 md:grid-cols-2 md:gap-y-0"
        >
            <div class="flex min-w-0 flex-col">
                {
                    leftCol.map((item) => (
                        <article class="border-b border-zinc-300 py-8 first:pt-0 dark:border-zinc-700 md:pr-4">
                            <div class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-0">
                                <span class="pt-0.5 text-sm font-normal tabular-nums text-zinc-400 dark:text-zinc-500">
                                    {item.id}
                                </span>
                                <div class="min-w-0">
                                    <a
                                        href={`/product-design/${item.slug}`}
                                        class="text-inherit no-underline transition-opacity duration-250 ease-in-out hover:opacity-80"
                                    >
                                        <h2 class="m-0 text-base font-bold leading-snug text-black dark:text-zinc-50">
                                            {item.title}
                                        </h2>
                                    </a>
                                    <p class="mb-0 mt-2 text-sm font-normal leading-relaxed text-black dark:text-zinc-300">
                                        {item.description}
                                    </p>
                                    <p class="mb-0 mt-2 text-xs leading-normal text-zinc-400 dark:text-zinc-500">{item.tags}</p>
                                </div>
                            </div>
                        </article>
                    ))
                }
            </div>
            <div class="flex min-w-0 flex-col">
                {
                    rightCol.map((item) => (
                        <article class="border-b border-zinc-300 py-8 dark:border-zinc-700 md:first:pt-0 md:pl-4">
                            <div class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-0">
                                <span class="pt-0.5 text-sm font-normal tabular-nums text-zinc-400 dark:text-zinc-500">
                                    {item.id}
                                </span>
                                <div class="min-w-0">
                                    <a
                                        href={`/product-design/${item.slug}`}
                                        class="text-inherit no-underline transition-opacity duration-250 ease-in-out hover:opacity-80"
                                    >
                                        <h2 class="m-0 text-base font-bold leading-snug text-black dark:text-zinc-50">
                                            {item.title}
                                        </h2>
                                    </a>
                                    <p class="mb-0 mt-2 text-sm font-normal leading-relaxed text-black dark:text-zinc-300">
                                        {item.description}
                                    </p>
                                    <p class="mb-0 mt-2 text-xs leading-normal text-zinc-400 dark:text-zinc-500">{item.tags}</p>
                                </div>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </div>
</div>
